createOrReplace

	table calendar

		/// Date column formatted as 'mm/dd/yyyy'. Primary key for calendar table.
		column Date
			dataType: dateTime
			formatString: mm/dd/yyyy
			sourceProviderType: date
			summarizeBy: none
			sourceColumn: Date

			annotation SummarizationSetBy = Automatic

			annotation UnderlyingDateTimeDataType = Date

		/// Calendar year which runs 01/01 to 12/31.
		column CY_Year
			dataType: int64
			formatString: 0
			summarizeBy: none
			sourceColumn: CY_Year

			changedProperty = SummarizeBy

			annotation SummarizationSetBy = User

		/// Fiscal year which runs from 07/01 to 06/30. 
		column FY_Year
			dataType: int64
			formatString: 0
			summarizeBy: none
			sourceColumn: FY_Year

			changedProperty = SummarizeBy

			annotation SummarizationSetBy = Automatic

		/// Calendar year shortened (i.e. '2022' is '22') for visualization labels.
		column CY_Short
			dataType: string
			summarizeBy: none
			sourceColumn: CY_Short
			sortByColumn: CY_Year

			annotation SummarizationSetBy = Automatic

		/// Fiscal year shortened (i.e. '2022' is '22') for visualization labels.
		column FY_Short
			dataType: string
			summarizeBy: none
			sourceColumn: FY_Short
			sortByColumn: FY_Year

			annotation SummarizationSetBy = Automatic

		/// Calendar year month in number format. Used to sort the CY_Month column properly. 
		column CY_Month_Num
			dataType: int64
			isHidden
			formatString: 0
			summarizeBy: none
			sourceColumn: CY_Month_Num

			changedProperty = IsHidden

			annotation SummarizationSetBy = User

		/// Month of calendar year formatted into 3 letters (i.e. - Jun) , ordered respectively by calendar year.
		column CY_Month
			dataType: string
			summarizeBy: none
			sourceColumn: CY_Month
			sortByColumn: CY_Month_Num

			changedProperty = SortByColumn

			annotation SummarizationSetBy = Automatic

		/// Calendar year month and year in format mmm-yy (i.e. - Jun-22 for June of 2022). 
		column CY_Month_Year
			dataType: string
			isHidden
			summarizeBy: none
			sourceColumn: CY_Month_Year
			sortByColumn: CY_Month_Year_Num

			changedProperty = SortByColumn

			changedProperty = IsHidden

			annotation SummarizationSetBy = Automatic

		/// Calendar month and year formatted as a number. Used for sorting the CY_Month_Year column. 
		column CY_Month_Year_Num
			dataType: int64
			formatString: 0
			summarizeBy: none
			sourceColumn: CY_Month_Year_Num

			annotation SummarizationSetBy = User

		/// Fiscal year month number. Used for sorting the FY_Month column properly.
		column FY_Month_Num
			dataType: int64
			isHidden
			formatString: 0
			summarizeBy: none
			sourceColumn: FY_Month_Num

			changedProperty = IsHidden

			annotation SummarizationSetBy = User

		/// Federal fiscal month formatted as text. (e.g. - 5 is '05')
		column Fiscal_Period
			dataType: string
			summarizeBy: none
			sourceColumn: Fiscal_Period
			sortByColumn: FY_Month_Num

			annotation SummarizationSetBy = Automatic

		/// Fiscal year month formatted as 3 letters. (e.g. - 'December' is 'Dec')
		column FY_Month
			dataType: string
			summarizeBy: none
			sourceColumn: FY_Month
			sortByColumn: FY_Month_Num

			changedProperty = SortByColumn

			annotation SummarizationSetBy = Automatic

		/// Federal fiscal year which runs from 10/01 to 09/30
		column Federal_Fiscal_Year
			dataType: int64
			formatString: 0
			summarizeBy: none
			sourceColumn: Federal_Fiscal_Year

			annotation SummarizationSetBy = User

		/// Week number of the calendar year
		column Week_of_Year
			dataType: int64
			formatString: 0
			summarizeBy: none
			sourceColumn: Week_of_Year

			annotation SummarizationSetBy = User

		/// Day of the week as a number for sorting the Day_of_Week column properly.
		/// Sun = 0, Sat = 6
		column Day_of_Week_Num
			dataType: int64
			isHidden
			formatString: 0
			summarizeBy: none
			sourceColumn: Day_of_Week_Num

			changedProperty = IsHidden

			annotation SummarizationSetBy = User

		/// Day of the week formatted into 3 letters. (e.g. - 'Monday' is 'Mon')
		column Day_of_Week
			dataType: string
			summarizeBy: none
			sourceColumn: Day_of_Week
			sortByColumn: Day_of_Week_Num

			changedProperty = SortByColumn

			annotation SummarizationSetBy = Automatic

		/// Day of the calendar year.
		column Day_of_Year
			dataType: int64
			formatString: 0
			summarizeBy: none
			sourceColumn: Day_of_Year

			annotation SummarizationSetBy = User

		/// Boolean marking weekdays as 'TRUE' and weekends as 'FALSE'
		column Is_Weekday
			dataType: boolean
			formatString: """TRUE"";""TRUE"";""FALSE"""
			summarizeBy: none
			sourceColumn: Is_Weekday

			annotation SummarizationSetBy = Automatic

		/// Boolean marking all dates in the last 5 and current fiscal year as 'TRUE', all else as 'FALSE'
		/// Used for filtering page to a reasonable timeframe.
		column Last_5_and_Current_FY
			dataType: boolean
			formatString: """TRUE"";""TRUE"";""FALSE"""
			summarizeBy: none
			sourceColumn: Last_5_and_Current_FY

			annotation SummarizationSetBy = Automatic

		/// Calendar year quarter formatted as "Q1". 
		/// Q1: 01/01 to 03/31
		/// Q2: 04/01 to 06/30
		/// Q3: 07/01 to 09/30
		/// Q4: 10/01 to 12/31
		column CY_Quarter
			dataType: string
			summarizeBy: none
			sourceColumn: CY_Quarter
			sortByColumn: CY_Quarter_Num

			changedProperty = SortByColumn

			annotation SummarizationSetBy = Automatic

		/// Fiscal year quarter formatted as "Q1".
		/// Q1: 07/01 to 09/30
		/// Q2: 10/01 to 12/31
		/// Q3: 01/01 to 03/31
		/// Q4: 04/01 to 06/30
		column FY_Quarter
			dataType: string
			summarizeBy: none
			sourceColumn: FY_Quarter
			sortByColumn: FY_Quarter_Num

			changedProperty = SortByColumn

			annotation SummarizationSetBy = Automatic

		/// Calendar year quarter as number. Used for sorting the CY_Quarter column properly.
		column CY_Quarter_Num
			dataType: int64
			isHidden
			summarizeBy: none
			sourceColumn: CY_Quarter_Num

			changedProperty = IsHidden

			annotation SummarizationSetBy = User

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		/// Fiscal year quarter as number. Used for sorting the FY_Quarter column properly.
		column FY_Quarter_Num
			dataType: int64
			isHidden
			formatString: 0
			summarizeBy: none
			sourceColumn: FY_Quarter_Num

			changedProperty = IsHidden

			annotation SummarizationSetBy = User

		/// Fiscal year month and year (e.g. 'Nov-22')
		column FY_Month_Year
			dataType: string
			summarizeBy: none
			sourceColumn: FY_Month_Year

			annotation SummarizationSetBy = Automatic

		/// Fiscal year month and year as number. Used for sorting the FY_Month_Year column properly. 
		column FY_Month_Year_Num
			dataType: int64
			formatString: 0
			summarizeBy: none
			sourceColumn: FY_Month_Year_Num

			changedProperty = IsHidden

			annotation SummarizationSetBy = User

		/// Fiscal year quarter and year (e.g. 'Q2-22' is Quarter 2 of 2022 or 10/01/2022 to 12/31/2022)
		column FY_Quarter_Year
			dataType: string
			summarizeBy: none
			sourceColumn: FY_Quarter_Year

			annotation SummarizationSetBy = Automatic

		/// Fiscal year quarter and year as number. Used for sorting FY_Quarter_Year column properly. 
		column FY_Quarter_Year_Num
			dataType: int64
			formatString: 0
			summarizeBy: none
			sourceColumn: FY_Quarter_Year_Num

			changedProperty = IsHidden

			annotation SummarizationSetBy = User

		/// Calendar year quarter and year (e.g. 'Q2-22' is Quarter 2 of 2022 or 04/01/2022 to 06/30/2022)
		column CY_Quarter_Year
			dataType: string
			summarizeBy: none
			sourceColumn: CY_Quarter_Year

			annotation SummarizationSetBy = Automatic

		/// Calendar year quarter and year as number. Used for sorting CY_Quarter_Year column properly. 
		column CY_Quarter_Year_Num
			dataType: int64
			summarizeBy: none
			sourceColumn: CY_Quarter_Year_Num

			changedProperty = IsHidden

			annotation SummarizationSetBy = User

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		partition calendar = m
			mode: import
			source =
					let
					    Source = Sql.Database(
                            "akelll3276yuxkzbgz77f3h4rm-vu3ae6b6lp7ermd2na6t75iyau.datawarehouse.fabric.microsoft.com", 
                            "RIT_RS_Reporting_Lakehouse"
                        ),

					    calendar = Source{[Schema="dbo",Item="calendar"]}[Data]
					in
					    calendar

		annotation PBI_NavigationStepName = Navigation

		annotation PBI_ResultType = Table